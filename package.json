{
  "name": "codex-app-server-client",
  "version": "0.1.4",
  "description": "TypeScript client for codex app-server",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "bindings:generate": "tsx scripts/generate-bindings.ts",
    "bindings:check": "tsx scripts/check-bindings.ts",
    "build": "tsc -p tsconfig.build.json",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "release:check": "npm run bindings:check && npm run typecheck && npm run build && npm run package:check && npm run docs:build",
    "package:check": "node scripts/check-package.mjs",
    "prepare": "npm run build",
    "test": "npm run test:unit",
    "test:all": "npm test && npm run test:integration",
    "test:unit": "vitest run tests/client tests/rpc tests/scripts tests/transport",
    "test:integration": "node scripts/runIntegrationTests.mjs",
    "test:watch": "vitest tests/client tests/rpc tests/scripts tests/transport",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "codex",
    "app-server",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/BrandonMJohnson/codex-client"
  },
  "author": "Brandon Johnson <brandon.johnson.mt@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0"
  }
}
